local function RemoveUIReward(isRunning)
    local player = Players.LocalPlayer or Players.PlayerAdded:Wait()
    if not player then
        return
    end
    
    local mouseStats = player:WaitForChild("PlayerScripts"):WaitForChild("Camera"):WaitForChild("MouseEnableStats")
    
    while isRunning() do
        local ok, results = pcall(function() return mouseStats:GetAttribute("Results") end)
        
        if ok and results == true then
            pcall(function() mouseStats:SetAttribute("Results", false) end)
            local rewardsGui = player.PlayerGui:FindFirstChild("Global")
                and player.PlayerGui.Global:FindFirstChild("Rewards")
            pcall(function() if rewardsGui then rewardsGui.Visible = false end end)
            task.wait(1)
            pcall(function() mouseStats:SetAttribute("Results", false) end)
        end
        task.wait(1)
    end
end

