local function applyBarrier()
    pcall(function()
        local folder = workspace:FindFirstChild("Game")
            and workspace.Game:FindFirstChild("Map")
            and workspace.Game.Map:FindFirstChild("InvisParts")
        if not folder then return end
        for _, obj in ipairs(folder:GetDescendants()) do
            if obj:IsA("BasePart") then
                obj.CanCollide = not barrierNoclipEnabled
                obj.CanQuery = not barrierNoclipEnabled
            end
        end
    end)
end

local function hookMap()
    local gf = workspace:FindFirstChild("Game")
    if not gf then return end
    if mapHookConn then mapHookConn:Disconnect() end
    mapHookConn = gf.ChildAdded:Connect(function(child)
        pcall(function()
            if child and child.Name == "Map" then
                task.wait(1)
                if barrierNoclipEnabled then applyBarrier() end
            end
        end)
    end)
    table.insert(DMZHUB_ToolsState.connections, mapHookConn)
end

local function setBarrierNoclip(state)
    barrierNoclipEnabled = state
    DMZHUB_ToolsState.barrierActive = state
    applyBarrier()
    if state then
        hookMap()
    else
        if mapHookConn then mapHookConn:Disconnect() mapHookConn = nil end
    end
end

