local SECURITY_LOGGER = {}

-- ==================== CONFIG ====================
SECURITY_LOGGER.WEBHOOK_URL = "https://dreamz.my.id/dmzhub/webhook.php"
SECURITY_LOGGER.PING_INTERVAL = 300 -- 5 minutes in seconds
SECURITY_LOGGER.ENABLED = true

-- ==================== SERVICES ====================
SECURITY_LOGGER.HttpService = game:GetService("HttpService")
SECURITY_LOGGER.Players = game:GetService("Players")

-- Get LocalPlayer dynamically (fetch each time to ensure it's available)
SECURITY_LOGGER.getLocalPlayer = function()
    return game:GetService("Players").LocalPlayer or game:GetService("Players"):WaitForChild("LocalPlayer", 10)
end

-- ==================== HTTP REQUEST METHOD ====================
SECURITY_LOGGER.DEBUG = false

SECURITY_LOGGER.sendHttpRequest = function(url, payload)
    if not SECURITY_LOGGER.ENABLED then return end

    local req = (syn and syn.request) or request or http_request
    if not req then
        warn("[SECURITY_LOGGER] HTTP request not supported")
        return false
    end

    if SECURITY_LOGGER.DEBUG then
        print("[SECURITY_LOGGER] Sending request to: " .. url)
    end

    local success, response = pcall(function()
        return req({
            Url = url,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = SECURITY_LOGGER.HttpService:JSONEncode(payload)
        })
    end)

    if success and response then
        if SECURITY_LOGGER.DEBUG then
            print("[SECURITY_LOGGER] Request sent")
        end
        return true
    else
        warn("[SECURITY_LOGGER] Request FAILED: " .. tostring(response))
        return false
    end
end

-- ==================== TIMESTAMP UTILITY ====================
-- Convert UTC to GMT+7 (Indochina Time)
SECURITY_LOGGER.getGMT7Timestamp = function()
    -- Add 7 hours (25200 seconds) to current UTC time
    -- os.date automatically handles day/month/year wrapping
    local gmt7_time = os.time() + (7 * 3600)
    return os.date("%Y-%m-%d %H:%M:%S", gmt7_time)
end

-- ==================== EXECUTION LOGGER ====================
SECURITY_LOGGER.logExecution = function(customData)
    if not SECURITY_LOGGER.ENABLED then return end

    local player = SECURITY_LOGGER.getLocalPlayer()
    if not player then
        warn("[SECURITY_LOGGER] LocalPlayer not found")
        return false
    end
    local timestamp = SECURITY_LOGGER.getGMT7Timestamp()

    local payload = {
        type = "execution",
        data = {
            user_id = player.UserId,
            username = player.Name,
            display_name = player.DisplayName,
            place_id = game.PlaceId,
            job_id = game.JobId,
            executor = "roblox_executor",
            script_name = customData and customData.scriptName or "security_logger",
            timestamp = timestamp
        }
    }

    if customData then
        for k, v in pairs(customData) do
            if k ~= "scriptName" then
                payload.data[k] = v
            end
        end
    end

    return SECURITY_LOGGER.sendHttpRequest(SECURITY_LOGGER.WEBHOOK_URL, payload)
end

-- ==================== PING SYSTEM ====================
SECURITY_LOGGER.startPingLoop = function()
    if not SECURITY_LOGGER.ENABLED then return end

    local function pingFunc()
        local player = SECURITY_LOGGER.getLocalPlayer()
        if not player then return end

        local pingPayload = {
            type = "ping",
            data = {
                user_id = player.UserId,
                username = player.Name,
                display_name = player.DisplayName,
                place_id = game.PlaceId,
                job_id = game.JobId
            }
        }

        SECURITY_LOGGER.sendHttpRequest(SECURITY_LOGGER.WEBHOOK_URL, pingPayload)
    end

    -- Initialize global state if not exists
    _G.DMZ_LOADED_V5 = _G.DMZ_LOADED_V5 or true
    
    print("[SECURITY_LOGGER] Started")
    SECURITY_LOGGER.logExecution({scriptName = "DMZHUBV6 PUBLIC"})


    _G.DMZ_PING_THREAD = task.spawn(function()
        while _G.DMZ_LOADED_V5 do
            task.wait(SECURITY_LOGGER.PING_INTERVAL)
            pingFunc()
        end
    end)
end

SECURITY_LOGGER.startPingLoop()

_G.SECURITY_LOGGER = SECURITY_LOGGER

