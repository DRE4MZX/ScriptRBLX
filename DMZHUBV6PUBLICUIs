local function backupCosmetic(cosmeticName)
    if not cosmeticsFolder then return false end
    local cosmetic = cosmeticsFolder:FindFirstChild(cosmeticName)
    if not cosmetic then return false end

    -- Skip jika sudah ada backup (jangan overwrite backup asli)
    if cosmeticBackup[cosmeticName] then return true end

    cosmeticBackup[cosmeticName] = {}
    for _, child in pairs(cosmetic:GetChildren()) do
        table.insert(cosmeticBackup[cosmeticName], child:Clone())
    end
    return true
end

local function copyCosmetic(sourceCosmetic, targetCosmetic)
    if not sourceCosmetic or not targetCosmetic then return false end

    for _, child in pairs(targetCosmetic:GetChildren()) do
        child:Destroy()
    end

    for _, child in pairs(sourceCosmetic:GetChildren()) do
        local cloned = child:Clone()
        cloned.Parent = targetCosmetic
    end

    return true
end

local function restoreCosmetic(cosmeticName)
    if not cosmeticBackup[cosmeticName] then return false end
    if not cosmeticsFolder then return false end

    local cosmetic = cosmeticsFolder:FindFirstChild(cosmeticName)
    if not cosmetic then return false end

    for _, child in pairs(cosmetic:GetChildren()) do
        child:Destroy()
    end

    for _, backedChild in pairs(cosmeticBackup[cosmeticName]) do
        local cloned = backedChild:Clone()
        cloned.Parent = cosmetic
    end

    return true
end

local function getCosmeticList()
    local list = {}
    if not cosmeticsFolder then return list end
    for _, cosmetic in pairs(cosmeticsFolder:GetChildren()) do
        if cosmetic:IsA("ModuleScript") or cosmetic:IsA("Folder") then
            table.insert(list, cosmetic.Name)
        end
    end
    table.sort(list)
    return list
end

