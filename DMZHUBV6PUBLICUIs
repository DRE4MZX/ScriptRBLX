local function stopShowBarriers()
    showBarriersEnabled = false
    if showBarriersLoop then
        pcall(function() task.cancel(showBarriersLoop) end)
        showBarriersLoop = nil
    end
    pcall(function()
        local folder = workspace:FindFirstChild("Game")
            and workspace.Game:FindFirstChild("Map")
            and workspace.Game.Map:FindFirstChild("InvisParts")
        if not folder then return end
        for _, obj in ipairs(folder:GetDescendants()) do
            if obj:IsA("BasePart") then
                obj.Material = Enum.Material.SmoothPlastic
                obj.Transparency = 1
            end
        end
    end)
end

local function startShowBarriers()
    showBarriersEnabled = true
    showBarriersLoop = task.spawn(function()
        local _self = coroutine.running()
        DMZHUB_ToolsState.showBarriersLoop = _self
        while showBarriersEnabled do
            pcall(function()
                local folder = workspace:FindFirstChild("Game")
                    and workspace.Game:FindFirstChild("Map")
                    and workspace.Game.Map:FindFirstChild("InvisParts")
                if folder then
                    for _, obj in ipairs(folder:GetDescendants()) do
                        if obj:IsA("BasePart") then
                            obj.Material = Enum.Material.Asphalt
                            obj.Color = showBarriersColor
                            if obj.Transparency == 1 then obj.Transparency = 0.5 end
                        end
                    end
                end
            end)
            task.wait(10)
        end
    end)
end

