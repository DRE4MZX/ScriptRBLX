local function applyLastSwap()
    for _, pair in pairs(lastSwap) do
        local a = pair.a
        local b = pair.b

        if a and b and a.Parent and b.Parent then
            local nameA = originalNames[a]
            local nameB = originalNames[b]

            local temp = "__TEMP__"
            a.Name = temp
            b.Name = nameA
            a.Name = nameB
        end
    end
end

local function resetEmotes()
    for emote, origName in pairs(originalNames) do
