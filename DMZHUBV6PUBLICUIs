-- ── CUSTOM POSITIONS (override per zone, persisted ke JSON)
local CUSTOM_TP_FILE = "DMZHUB_TeleportPositions.json"
local customTPPositions = {}

local function autoTP_loadCustomPositions()
    customTPPositions = {}
    if not (readfile and isfile) then return end
    local ok, raw = pcall(function()
        if isfile(CUSTOM_TP_FILE) then
            return readfile(CUSTOM_TP_FILE)
        end
    end)
    if not ok or not raw or #raw == 0 then return end
    local ok2, decoded = pcall(function()
        return HttpService:JSONDecode(raw)
    end)
    if ok2 and type(decoded) == "table" then
        for k, v in pairs(decoded) do
            if type(v) == "table" and v.X and v.Y and v.Z then
                customTPPositions[k] = Vector3.new(v.X, v.Y, v.Z)
            end
        end
    end
end

local function autoTP_saveCustomPositions()
    if not writefile then return end
    local serialized = {}
    for k, v in pairs(customTPPositions) do
        serialized[k] = { X = v.X, Y = v.Y, Z = v.Z }
    end
    pcall(function()
        writefile(CUSTOM_TP_FILE, HttpService:JSONEncode(serialized))
    end)
end

-- resolver: custom dulu, kalau ga ada baru fallback ke builtin
local function autoTP_getPosition(mapName)
    if not mapName then return nil end
    if customTPPositions[mapName] then
        return customTPPositions[mapName]
    end
    return tpPositions[mapName]
end

autoTP_loadCustomPositions()

-- helper log dengan severity eksplisit (pesan netral, hindari bocor mekanik)
local function autoTP_log(msg, severity)
    msg = tostring(msg)
    if severity == "success" then
        logBox:Success(msg)
    elseif severity == "error" then
        logBox:Error(msg)
    elseif severity == "warning" then
        logBox:Warning(msg)
    else
        logBox:Info(msg)
    end
end

local function autoTP_isLocalPlayerInGame()
    local playersFolder = AutoTP_gameFolder:FindFirstChild("Players")
    if not playersFolder then return false end
    for _, obj in ipairs(playersFolder:GetChildren()) do
        if obj.Name == LocalPlayer.Name then
            return true
        end
    end
    return false
end

local function autoTP_waitPlayerInGame(timeout)
    timeout = timeout or 10
    local t = 0
    while t < timeout do
        if autoTP_isLocalPlayerInGame() then return true end
        task.wait(0.2)
        t += 0.2
    end
    return false
end

local function autoTP_isTeleporterNearby(targetPos, maxDistance)
    local effects = AutoTP_gameFolder:FindFirstChild("Effects")
    if not effects then return false end
    local deployables = effects:FindFirstChild("Deployables")
    if not deployables then return false end

    for _, obj in ipairs(deployables:GetChildren()) do
        if obj:IsA("Model") and obj.Name == "Teleporter" then
            local tpPos = obj.WorldPivot.Position
            local dist = (tpPos - targetPos).Magnitude
            if dist <= maxDistance then
                return true, tpPos
            end
        end
    end
    return false
end

local function autoTP_waitLoadFinish(loadMap)
    if not loadMap then return end
    if not loadMap.Visible then return end
    while loadMap.Visible do
        loadMap:GetPropertyChangedSignal("Visible"):Wait()
    end
end

local function autoTP_isRewardsVisible()
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if not pg then return false end
    local global = pg:FindFirstChild("Global")
    if not global then return false end
    local rewards = global:FindFirstChild("Rewards")
    if not rewards then return false end
    return rewards.Visible == true
end

local function autoTP_doAutoTP(mapName)
    local pg = LocalPlayer:WaitForChild("PlayerGui")
    local global = pg:WaitForChild("Global")
    local loadMap = global:WaitForChild("LoadMap")

    autoTP_waitLoadFinish(loadMap)
    task.wait(1)

    local tpPos = autoTP_getPosition(mapName)
    if tpPos then
        autoTP_log("Preparing", "info")
    else
        autoTP_log("Unsupported zone", "error")
        return
    end

    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {}

    local rayResult
    local startTime = tick()
    local timeout = 5
    repeat
        rayResult = workspace:Raycast(
            tpPos + Vector3.new(0, 50, 0),
            Vector3.new(0, -1000, 0),
            raycastParams
        )
        if rayResult then break end
        task.wait(0.2)
    until tick() - startTime >= timeout

    if not rayResult then
        autoTP_log("Failed", "error")
        return
    end

    local hitPos = rayResult.Position
    local teleportCFrame = CFrame.new(hitPos)

    local exists = autoTP_isTeleporterNearby(hitPos, 5)
    if exists then
        autoTP_log("Skipped", "info")
        return
    end

    autoTP_log("Working...", "info")

    ReplicatedStorage.Events.Character.ToolAction:FireServer(0, 16)
    task.wait(1)
    ReplicatedStorage.Events.Character.ToolAction:FireServer(1, {
        "Teleporter",
        teleportCFrame
    })

    autoTP_log("Done", "success")
end

local function autoTP_tryRoundTP()
    if not _G.MapEnabled then return end
    if not autoTP_currentMap then return end

    local roundStarted   = AutoTP_Stats:GetAttribute("RoundStarted")
    local timer          = tonumber(AutoTP_Stats:GetAttribute("Timer"))
    local rewardsVisible = autoTP_isRewardsVisible()

    if roundStarted == false and timer == 0 and rewardsVisible == true then
        local now = tick()
        if now - autoTP_lastRoundTP < 2 then return end
        if autoTP_tpCooldown then return end
        if not autoTP_isLocalPlayerInGame() then return end

        autoTP_lastRoundTP = now
        autoTP_tpCooldown = true

        autoTP_log("Trigger received", "info")

        task.spawn(function()
            autoTP_doAutoTP(autoTP_currentMap)
            task.delay(1, function()
                autoTP_tpCooldown = false
            end)
        end)
    end
end

local function autoTP_handleMapChange(newMap)
    if not _G.MapEnabled then return end

    task.spawn(function()
        local pg = LocalPlayer:WaitForChild("PlayerGui")
        local global = pg:WaitForChild("Global")
        local loadMap = global:WaitForChild("LoadMap")

        autoTP_waitLoadFinish(loadMap)

        if not autoTP_waitPlayerInGame(5) then
            autoTP_log("Awaiting state", "warning")
            return
        end

        if autoTP_tpCooldown then return end
        autoTP_tpCooldown = true

        autoTP_log("Zone changed", "info")
        autoTP_doAutoTP(newMap)

        task.delay(0.5, function()
            autoTP_tpCooldown = false
        end)
    end)
end

local function autoTP_hookMap(mapFolder)
    if _G.AutoTP_MapNameConnection then
        _G.AutoTP_MapNameConnection:Disconnect()
        _G.AutoTP_MapNameConnection = nil
    end
    if not mapFolder then return end

    autoTP_currentMap = mapFolder:GetAttribute("MapName")
    autoTP_log("Tracking", "info")

    autoTP_handleMapChange(autoTP_currentMap)

    _G.AutoTP_MapNameConnection = mapFolder:GetAttributeChangedSignal("MapName"):Connect(function()
        local newMap = mapFolder:GetAttribute("MapName")
        if newMap == autoTP_currentMap then return end
        autoTP_currentMap = newMap
        autoTP_log("Zone update", "info")
        autoTP_handleMapChange(newMap)
    end)
end

local function autoTP_startSystem()
    autoTP_log("Module active", "success")
    autoTP_hookMap(AutoTP_gameFolder:FindFirstChild("Map"))

    _G.AutoTP_MapWatcher = AutoTP_gameFolder.ChildAdded:Connect(function(child)
        if child.Name == "Map" then
            autoTP_hookMap(child)
        end
    end)
end

local function autoTP_stopSystem()
    autoTP_log("Module idle", "warning")
    if _G.AutoTP_MapNameConnection then
        _G.AutoTP_MapNameConnection:Disconnect()
        _G.AutoTP_MapNameConnection = nil
    end
    if _G.AutoTP_MapWatcher then
        _G.AutoTP_MapWatcher:Disconnect()
        _G.AutoTP_MapWatcher = nil
    end
end

