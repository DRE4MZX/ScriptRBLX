-- // DMZFunction: Managed thread wrapper //
function Library:dmzfunction(name, callback)
    LibraryThreads[name] = {Running = false, Callback = callback}
end

function Library:SetThreadState(name, state)
    local thread = LibraryThreads[name]
    if not thread then return end

    thread.Running = state

    if state then
        task.spawn(function()
            local function isRunning()
                return thread.Running
            end
            thread.Callback(isRunning)
        end)
    end
end

function Library:StopThread(name)
    if LibraryThreads[name] then
        LibraryThreads[name].Running = false
    end
end

function Library:StopAllThreads()
    for _, thread in pairs(LibraryThreads) do
        thread.Running = false
    end
end

function Library:RegisterAccent(instance, property)
    table.insert(self.AccentObjects, {Instance = instance, Property = property})
end

function Library:RegisterElementOpacity(instance, property)
    table.insert(self.ElementOpacityObjects, {Instance = instance, Property = property})
end

function Library:UpdateAccent(color)
    for _, obj in ipairs(self.AccentObjects) do
        if obj.Instance and obj.Instance.Parent then
            obj.Instance[obj.Property] = color
        end
    end
    for _, win in ipairs(self.Windows) do
        if win.CurrentTab and win.CurrentTab.Btn and win.CurrentTab.Btn.Parent then
            win.CurrentTab.Btn.TextColor3 = color
        end
    end
end

function Library:UpdateElementOpacity(opacity)
    for _, obj in ipairs(self.ElementOpacityObjects) do
        if obj.Instance and obj.Instance.Parent then
            obj.Instance[obj.Property] = opacity
        end
    end
end

function Library:SetTheme(themeConfig)
    local accentChanged = false
    local opacityChanged = false
    for k, v in pairs(themeConfig) do
        if self.Theme[k] then
            if k == "Accent" and self.Theme[k] ~= v then
                accentChanged = true
            elseif k == "ElementOpacity" and self.Theme[k] ~= v then
                opacityChanged = true
            end
            self.Theme[k] = v
        end
    end
    if accentChanged then
        self:UpdateAccent(self.Theme.Accent)
    end
    if opacityChanged then
        self:UpdateElementOpacity(self.Theme.ElementOpacity)
    end
end

