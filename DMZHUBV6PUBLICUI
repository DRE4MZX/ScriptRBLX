                Size = UDim2.new(0.5, 0, 0, 20),
                Text = tostring(SliderVal),
                Font = Enum.Font.FredokaOne,
                TextColor3 = Library.Theme.Accent,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Right
            })

            local TrackBg = Create("TextButton", {
                Parent = SliderFrame,
                BackgroundColor3 = Library.Theme.Background,
                Position = UDim2.new(0, 12, 0, 32),
                Size = UDim2.new(1, -24, 0, 6),
                Text = "",
                AutoButtonColor = false
            })
            Create("UICorner", { Parent = TrackBg, CornerRadius = UDim.new(1, 0) })

            local TrackFill = Create("Frame", {
                Parent = TrackBg,
                BackgroundColor3 = Library.Theme.Accent,
                Size = UDim2.new((SliderVal - Min) / (Max - Min), 0, 1, 0)
            })
            Create("UICorner", { Parent = TrackFill, CornerRadius = UDim.new(1, 0) })
            Library:RegisterAccent(TrackFill, "BackgroundColor3")
            Library:RegisterAccent(ValueText, "TextColor3")

            local AccentLine = Create("Frame", {
                Parent = TrackFill,
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(1, 0, 0.5, 0),
                Size = UDim2.new(0, 2, 1, 8),
                BorderSizePixel = 0
            })

            local dragging = false

            local function updateSlider(input)
                local mathHelper = math.clamp((input.Position.X - TrackBg.AbsolutePosition.X) / TrackBg.AbsoluteSize.X, 0, 1)
                local rawValue = Min + (Max - Min) * mathHelper
                local snappedValue = math.floor(rawValue / Increment + 0.5) * Increment
                SliderVal = math.clamp(snappedValue, Min, Max)
                
                ValueText.Text = tostring(SliderVal)
                Tween(TrackFill, {Size = UDim2.new((SliderVal - Min) / (Max - Min), 0, 1, 0)}, 0.1)
                
                if config.Flag then Library.Flags[config.Flag] = SliderVal end
                if config.Callback then config.Callback(SliderVal) end
            end

            TrackBg.MouseEnter:Connect(function()
                if not dragging then
                    Tween(AccentLine, {Size = UDim2.new(0, 3, 1, 10)}, 0.15)
                end
            end)

            TrackBg.MouseLeave:Connect(function()
                if not dragging then
                    Tween(AccentLine, {Size = UDim2.new(0, 2, 1, 8)}, 0.15)
                end
            end)

            TrackBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    Tween(AccentLine, {Size = UDim2.new(0, 4, 1, 12)}, 0.15)
                    updateSlider(input)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                    Tween(AccentLine, {Size = UDim2.new(0, 2, 1, 8)}, 0.15)
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    updateSlider(input)
                end
            end)

            local SliderController = {}
            function SliderController:SetValue(v)
                v = math.clamp(math.floor(v / Increment + 0.5) * Increment, Min, Max)
                SliderVal = v
                ValueText.Text = tostring(v)
                TrackFill.Size = UDim2.new((v - Min) / (Max - Min), 0, 1, 0)
                if config.Flag then Library.Flags[config.Flag] = v end
                if config.Callback then config.Callback(v) end
            end
            return SliderController
        end

