        function TabComponents:CreateDropdown(config)
            local DropdownVal = config.CurrentValue or (config.Options and config.Options[1]) or "Select..."
            if config.Flag then Library.Flags[config.Flag] = DropdownVal end
            local useSearch = config.UseSearch or false
            local allOptions = config.Options or {}
            local displayedOptions = allOptions

            local DropdownFrame = Create("TextButton", {
                Parent = TabPage,
                BackgroundColor3 = Library.Theme.ElementBg,
                BackgroundTransparency = Library.Theme.ElementOpacity,
                Size = UDim2.new(0.97, 0, 0, 38),
                Text = "",
                AutoButtonColor = false
            })
            Create("UICorner", { Parent = DropdownFrame, CornerRadius = UDim.new(0, 8) })
            Create("UIStroke", { Parent = DropdownFrame, Color = Library.Theme.Border, Thickness = 1 })
            Library:RegisterElementOpacity(DropdownFrame, "BackgroundTransparency")

            local DropdownText = Create("TextLabel", {
                Parent = DropdownFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 12, 0, 0),
                Size = UDim2.new(0.7, 0, 1, 0),
                Text = config.Name,
                Font = Enum.Font.SourceSansSemibold,
                TextColor3 = Library.Theme.Text,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local ValueText = Create("TextLabel", {
                Parent = DropdownFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0.7, 0, 0, 0),
                Size = UDim2.new(0.3, -12, 1, 0),
                Text = DropdownVal,
                Font = Enum.Font.SourceSansSemibold,
                TextColor3 = Library.Theme.Accent,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Right,
                TextTruncate = Enum.TextTruncate.AtEnd
            })
            Library:RegisterAccent(ValueText, "TextColor3")

            local SearchBox = nil

            local DropdownMenu = Create("ScrollingFrame", {
                Parent = TabPage,
                BackgroundColor3 = Library.Theme.ElementBg,
                BackgroundTransparency = Library.Theme.ElementOpacity,
                Position = UDim2.new(0, 0, 0, 0),
                Size = UDim2.new(0.5, 0, 0, 0),
                Visible = false,
                ZIndex = 200,
                ClipsDescendants = true,
                ScrollBarThickness = 2,
                ScrollBarImageColor3 = Library.Theme.Accent,
                CanvasSize = UDim2.new(0, 0, 0, 0)
            })
            Create("UICorner", { Parent = DropdownMenu, CornerRadius = UDim.new(0, 8) })
            Create("UIStroke", { Parent = DropdownMenu, Color = Library.Theme.Border, Thickness = 1 })
            Library:RegisterElementOpacity(DropdownMenu, "BackgroundTransparency")
            Library:RegisterAccent(DropdownMenu, "ScrollBarImageColor3")

            local MenuPadding = Create("UIPadding", {
                Parent = DropdownMenu,
                PaddingTop = UDim.new(0, 4),
                PaddingBottom = UDim.new(0, 4),
                PaddingLeft = UDim.new(0, 4),
                PaddingRight = UDim.new(0, 8)
            })

            local MenuLayout = Create("UIListLayout", {
                Parent = DropdownMenu,
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 4)
            })

            local function UpdateMenuPosition()
                local framePos = DropdownFrame.AbsolutePosition
                local frameSize = DropdownFrame.AbsoluteSize
                DropdownMenu.Position = UDim2.new(0, framePos.X - TabPage.AbsolutePosition.X, 0, framePos.Y - TabPage.AbsolutePosition.Y + frameSize.Y + 4)
            end

            local ToggleMenu
            local RefreshOptions

            function RefreshOptions()
                for _, child in pairs(DropdownMenu:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end

                for i, option in ipairs(displayedOptions) do
                    local OptionBtn = Create("TextButton", {
                        Parent = DropdownMenu,
                        BackgroundColor3 = Library.Theme.ElementBg,
                        BackgroundTransparency = Library.Theme.ElementOpacity,
                        Size = UDim2.new(1, 0, 0, 30),
                        Text = option,
                        Font = Enum.Font.SourceSansSemibold,
                        TextColor3 = Library.Theme.Text,
                        TextSize = 12,
                        AutoButtonColor = false,
                        LayoutOrder = i
                    })
                    Create("UICorner", { Parent = OptionBtn, CornerRadius = UDim.new(0, 6) })
                    Library:RegisterElementOpacity(OptionBtn, "BackgroundTransparency")

                    OptionBtn.MouseEnter:Connect(function()
                        Tween(OptionBtn, {BackgroundColor3 = Library.Theme.Accent}, 0.15)
                        Tween(OptionBtn, {TextColor3 = Library.Theme.Background}, 0.15)
                    end)

                    OptionBtn.MouseLeave:Connect(function()
                        Tween(OptionBtn, {BackgroundColor3 = Library.Theme.ElementBg}, 0.15)
                        Tween(OptionBtn, {TextColor3 = Library.Theme.Text}, 0.15)
                    end)

                    OptionBtn.MouseButton1Click:Connect(function()
                        DropdownVal = option
                        ValueText.Text = option
                        if config.Flag then Library.Flags[config.Flag] = DropdownVal end
                        if config.Callback then config.Callback(DropdownVal) end
                        ToggleMenu()
                        if SearchBox then SearchBox.Text = "" end
                    end)
                end

                MenuLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    local contentHeight = MenuLayout.AbsoluteContentSize.Y + 8
                    local maxHeight = 100
                    local displayHeight = math.min(contentHeight, maxHeight)
                    DropdownMenu.Size = UDim2.new(1, 0, 0, displayHeight)
                    DropdownMenu.CanvasSize = UDim2.new(0, 0, 0, contentHeight)
                end)
            end

            function ToggleMenu()
                DropdownMenu.Visible = not DropdownMenu.Visible
                if DropdownMenu.Visible then
                    UpdateMenuPosition()
                    if useSearch and not SearchBox then
                        SearchBox = Create("TextBox", {
                            Parent = DropdownMenu,
                            BackgroundColor3 = Library.Theme.Background,
                            Position = UDim2.new(0, 0, 0, 0),
                            Size = UDim2.new(1, 0, 0, 32),
                            Text = "",
                            PlaceholderText = "Search...",
                            PlaceholderColor3 = Library.Theme.TextDim,
                            Font = Enum.Font.SourceSansSemibold,
                            TextColor3 = Library.Theme.Text,
                            TextSize = 11,
                            ClearTextOnFocus = false,
                            ZIndex = 201,
                            LayoutOrder = 0
                        })
                        Create("UICorner", { Parent = SearchBox, CornerRadius = UDim.new(0, 6) })
                        Create("UIPadding", { Parent = SearchBox, PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8) })
                        
                        SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
                            local query = string.lower(SearchBox.Text)
                            displayedOptions = {}
                            for _, option in ipairs(allOptions) do
                                if query == "" or string.find(string.lower(option), query, 1, true) then
                                    table.insert(displayedOptions, option)
                                end
                            end
                            RefreshOptions()
                        end)
                        
                        SearchBox:CaptureFocus()
                    elseif SearchBox then
                        SearchBox.Text = ""
                        SearchBox:CaptureFocus()
                    end
                else
                    if SearchBox then
                        SearchBox:Destroy()
                        SearchBox = nil
                    end
                end
            end

            DropdownFrame.MouseButton1Click:Connect(function() ToggleMenu() end)

            RefreshOptions()
        end

        return TabComponents
    end

    local NotifContainer = Create("Frame", {
