    -- Developer-only section
    local DeveloperUserId = 122707142
    if Players.LocalPlayer.UserId == DeveloperUserId then
        SettingsTab:CreateSection("Developer")
        
        SettingsTab:CreateToggle({
            Name = "Debug Mode",
            CurrentValue = DebugMode,
            Flag = "DebugModeToggle",
