        Create("UIStroke", { Parent = NFrame, Color = Library.Theme.Border, Thickness = 1.5, Transparency = 0.3 })

        local Glow = Create("Frame", {
            Parent = NFrame,
            BackgroundColor3 = Library.Theme.Accent,
            Size = UDim2.new(0, 3, 1, -16),
            Position = UDim2.new(0, 8, 0.5, 0),
            AnchorPoint = Vector2.new(0, 0.5)
        })
        Create("UICorner", { Parent = Glow, CornerRadius = UDim.new(1, 0) })
        Library:RegisterAccent(Glow, "BackgroundColor3")

        Create("TextLabel", {
            Parent = NFrame,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 20, 0, 10),
            Size = UDim2.new(1, -30, 0, 16),
            Text = Title,
            Font = Enum.Font.FredokaOne,
            TextColor3 = Library.Theme.Text,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left
        })

        Create("TextLabel", {
            Parent = NFrame,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 20, 0, 28),
            Size = UDim2.new(1, -30, 0, 20),
            Text = Content,
            Font = Enum.Font.SourceSansSemibold,
            TextColor3 = Library.Theme.TextDim,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true
        })

        Tween(NFrame, {Position = UDim2.new(0, 0, 0, 0)}, 0.4, Enum.EasingStyle.Back)

        task.delay(Duration, function()
            if NFrame and NFrame.Parent then
                local t = Tween(NFrame, {Position = UDim2.new(1, 350, 0, 0), GroupTransparency = 1}, 0.3)
                t.Completed:Connect(function() 
                    if NFrame and NFrame.Parent then
                        NFrame:Destroy() 
                    end
                end)
            end
        end)
    end

    -- Auto-create Settings Tab (always at bottom)
    local SettingsTab = Window:CreateTab("Settings", nil, 9999, true)
    local SettingsPage = SettingsTab.Page

    local DebugMode = loadedSettings.DebugMode or false
    
