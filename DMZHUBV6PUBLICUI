-- // Visual State Cleanup (restore emotes/cosmetics dari execution sebelumnya) //
local prevVisualState = getgenv()["DMZHUB_VisualState"]
if prevVisualState then
    -- Disconnect old listeners
    if prevVisualState.connections then
        for _, conn in pairs(prevVisualState.connections) do
            pcall(function() conn:Disconnect() end)
        end
    end
    -- Restore emote names
    if prevVisualState.originalNames then
        for emote, origName in pairs(prevVisualState.originalNames) do
            pcall(function()
                if emote and emote.Parent then
                    emote.Name = origName
                end
            end)
        end
    end
    -- Restore cosmetics
    if prevVisualState.cosmeticBackup and prevVisualState.cosmeticsFolder then
        for cosmeticName, backedChildren in pairs(prevVisualState.cosmeticBackup) do
            pcall(function()
                local cosmetic = prevVisualState.cosmeticsFolder:FindFirstChild(cosmeticName)
                if cosmetic then
                    for _, child in pairs(cosmetic:GetChildren()) do
                        child:Destroy()
                    end
                    for _, backed in pairs(backedChildren) do
                        local cloned = backed:Clone()
                        cloned.Parent = cosmetic
                    end
                end
            end)
        end
    end
end

