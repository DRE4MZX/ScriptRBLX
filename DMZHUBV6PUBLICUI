        Callback = function(v)
            local r = Library.Theme.Accent.R
            local b = Library.Theme.Accent.B
            Library:SetTheme({Accent = Color3.fromRGB(math.floor(r * 255), v, math.floor(b * 255))})
            SaveCurrentSettings()
        end
    })

    SettingsSliders.AccentB = SettingsTab:CreateSlider({
        Name = "Accent Blue",
        Range = {0, 255},
        Increment = 1,
        CurrentValue = math.floor(Library.Theme.Accent.B * 255),
        Flag = "SettingsAccentB",
        Callback = function(v)
            local r = Library.Theme.Accent.R
            local g = Library.Theme.Accent.G
            Library:SetTheme({Accent = Color3.fromRGB(math.floor(r * 255), math.floor(g * 255), v)})
            SaveCurrentSettings()
        end
    })

    SettingsSliders.Glass = SettingsTab:CreateSlider({
        Name = "Glass Opacity",
        Range = {0, 100},
        Increment = 1,
        CurrentValue = math.floor(Library.Theme.GlassOpacity * 100),
        Flag = "SettingsGlassOpacity",
        Callback = function(v)
            Library:SetTheme({GlassOpacity = v / 100})
            MainFrame.BackgroundTransparency = Library.Theme.GlassOpacity
            SaveCurrentSettings()
        end
    })

    SettingsSliders.Element = SettingsTab:CreateSlider({
        Name = "Element Opacity",
        Range = {0, 100},
        Increment = 1,
        CurrentValue = math.floor(Library.Theme.ElementOpacity * 100),
        Flag = "SettingsElementOpacity",
