        Library.SettingsManager:SaveSettings({
            ThemeAccent = {math.floor(Library.Theme.Accent.R * 255), math.floor(Library.Theme.Accent.G * 255), math.floor(Library.Theme.Accent.B * 255)},
            GlassOpacity = Library.Theme.GlassOpacity,
            UITransparency = Library.Theme.ElementOpacity,
            Background = {math.floor(Library.Theme.Background.R * 255), math.floor(Library.Theme.Background.G * 255), math.floor(Library.Theme.Background.B * 255)},
            ElementBg = {math.floor(Library.Theme.ElementBg.R * 255), math.floor(Library.Theme.ElementBg.G * 255), math.floor(Library.Theme.ElementBg.B * 255)},
            ProfileCardHidden = not ProfileSidebar.Visible,
            DebugMode = DebugMode
        })
    end
    
    local function DebugLog(...)
