        function TabComponents:CreateLog(config)
            local LogFrame = Create("Frame", {
                Parent = TabPage,
                BackgroundColor3 = Library.Theme.ElementBg,
                BackgroundTransparency = Library.Theme.ElementOpacity,
                Size = UDim2.new(0.97, 0, 0, 100),
                BorderSizePixel = 0
            })
            Create("UICorner", { Parent = LogFrame, CornerRadius = UDim.new(0, 8) })
            Create("UIStroke", { Parent = LogFrame, Color = Library.Theme.Border, Thickness = 1 })
            Library:RegisterElementOpacity(LogFrame, "BackgroundTransparency")

            local ScrollingFrame = Create("ScrollingFrame", {
                Parent = LogFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -8, 1, -8),
                Position = UDim2.new(0, 4, 0, 4),
                ScrollBarThickness = 4,
                ScrollBarImageColor3 = Library.Theme.Accent,
                CanvasSize = UDim2.new(0, 0, 0, 0),
                BorderSizePixel = 0,
                ClipsDescendants = true
            })

            local logEntries = {}
            local maxEntries = config.MaxEntries or 50
            local currentYPos = 0

            local function addLog(message, color)
                color = color or Library.Theme.Text
                
                local timestamp = "[" .. os.date("%H:%M:%S") .. "]"
                local fullText = timestamp .. " " .. message
                
                local entry = Create("TextLabel", {
                    Parent = ScrollingFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, currentYPos),
                    Size = UDim2.new(1, -4, 0, 18),
                    Text = fullText,
                    Font = Enum.Font.SourceSans,
                    TextColor3 = color,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Top,
                    TextWrapped = true
                })

                table.insert(logEntries, {
                    label = entry,
                    height = 18
                })

                currentYPos = currentYPos + 18

                if #logEntries > maxEntries then
                    local removed = table.remove(logEntries, 1)
                    removed.label:Destroy()
                    currentYPos = currentYPos - removed.height
                    
                    for i, data in ipairs(logEntries) do
                        data.label.Position = UDim2.new(0, 0, 0, (i - 1) * 18)
                    end
                    currentYPos = #logEntries * 18
                end

                ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, currentYPos + 4)
                task.wait()
                ScrollingFrame.CanvasPosition = Vector2.new(0, math.max(0, currentYPos - ScrollingFrame.AbsoluteSize.Y + 20))
            end

            local function clearLog()
                for _, data in ipairs(logEntries) do
                    data.label:Destroy()
                end
                logEntries = {}
                currentYPos = 0
                ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
                ScrollingFrame.CanvasPosition = Vector2.new(0, 0)
            end

            local LogController = {}
            function LogController:AddLog(message, color)
                addLog(message, color)
            end
            function LogController:Clear()
                clearLog()
            end
            function LogController:Info(message)
                addLog(message, Library.Theme.Text)
            end
            function LogController:Success(message)
                addLog(message, Color3.fromRGB(0, 210, 120))
            end
            function LogController:Error(message)
                addLog(message, Color3.fromRGB(235, 75, 75))
            end
            function LogController:Warning(message)
                addLog(message, Color3.fromRGB(255, 185, 50))
            end
            return LogController
        end

