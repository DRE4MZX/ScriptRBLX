    })
    Create("UIListLayout", { Parent = NotifContainer, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8), VerticalAlignment = Enum.VerticalAlignment.Bottom })

    function Library:Notify(config)
        local Title = config.Title or "Notification"
        local Content = config.Content or ""
        local Duration = config.Duration or 5

        local NFrame = Create("CanvasGroup", {
            Parent = NotifContainer,
            BackgroundColor3 = Library.Theme.Background,
            BackgroundTransparency = Library.Theme.GlassOpacity,
            Size = UDim2.new(1, 0, 0, 60),
            ZIndex = 51,
            Position = UDim2.new(1, 350, 0, 0),
            GroupTransparency = 0
        })
